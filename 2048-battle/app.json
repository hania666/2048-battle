        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.battle2048.app",
      "googleMobileAdsAppId": "ca-app-pub-7052877159805288~1929926938"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "react-native-google-mobile-ads"
    ],
    "extra": {
      "eas": {
        "projectId": "4a52ae5e-3d64-4040-82cf-e7a717f3361a"
      }
    }
